    "workspaceMarkers": ["build.zig", "build.zig.zon"],
    "server": {
        "cmd": ["zls"]
    },
    "capabilities": {
        "workspaceSymbol": { "stringPrefilter": true, "timeoutMs": 5000 }
    }
}
