{
    "name": "starpls",
    "version": "0.1.0",
    "langIds": ["starlark"],
    "fileGlobs": [
        "**/*.star",
        "**/*.bzl",
        "**/BUILD",
        "**/BUILD.bazel",
        "**/WORKSPACE",
        "**/WORKSPACE.bazel",
        "**/MODULE.bazel"
    ],
    "workspaceMarkers": ["WORKSPACE", "WORKSPACE.bazel", "MODULE.bazel"],
    "server": {
        "cmd": ["starpls", "server"]
    },
    "capabilities": {
        "workspaceSymbol": { "stringPrefilter": true, "timeoutMs": 5000 }
    }
}
